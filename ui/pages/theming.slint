import { UAppTheme } from "../sleek-ui/app-theme.slint";
import { UTitle, UText, UCode, ULink } from "../sleek-ui/widgets.slint";

import { DocTitle, DocSection, DocCode } from "../components/doc-widgets.slint";
import { PageBase } from "../components/page-base.slint";
import { AppLogic } from "../app-logic.slint";
import { UMenuLogic } from "../sleek-ui/widgets/menu/menu.slint";


component Spacer inherits Rectangle {
    height: UAppTheme.spacing-bigger;
}

export component ThemingPage inherits PageBase {
    UTitle {
        level: 3;
        text: "Theming";
    }

    DocSection {
        title: "Theme configuration";
        description-md: @markdown(
			"The `UAppTheme` global comes with all the design token used in sleek-ui, however, all the design token properties are `out`.\n"
			"In order to modify the theme, you must use the `light` and `dark` properties of type [UAppThemeConfig]() so that the application theme can automatically "
			"switch between the light and dark color schemes using the `Palette.color-scheme` property."
		);
        link-clicked(id) => {
            root.scroll-to(config-struct.y);
            config-struct.trigger-signal();
        }
    }

    Spacer { }

    DocSection {
        description-md: @markdown(
			"Start by creating a global with two properties of type `UAppThemeConfig` that will contain your custom light and dark themes.\n"
			"You can use the default theme configuration in [UAppTheme](https://github.com/uAtomicBoolean/sleek-ui/blob/main/ui/sleek-ui/app-theme.slint) to start with a base in your theme."
		);
        link-clicked(url) => {
            Platform.open-url(url);
        }
    }

    DocCode {
        code: "import { UAppThemeConfig } from \"@sleek-ui/structs/theme.slint\";\n\nexport global MyCustomTheme {\n    in-out property <UAppThemeConfig> custom-light: {\n        // Your theme declaration.\n    };\n    in-out property <UAppThemeConfig> custom-dark: {\n        // Your theme declaration.\n    };\n}";
    }

    Spacer { }

    DocSection {
        description-md: @markdown(
			"In your logic, you can then replace the default theme with your custom theme.\n"
			"Don't forget to export both the `UAppTheme` and `MyCustomTheme` globals from your main slint file to make them available in your backend."
		);
    }

    DocCode {
        code: "// Here the example is in Rust.\nlet ui = AppWindow::new();\n\nlet app_theme = ui.global::<UAppTheme>();\nlet custom_theme = ui.global::<MyCustomTheme>();\n\napp_theme.set_light(custom_theme.get_custom_light());\napp_theme.set_light(custom_theme.get_custom_dark());";
    }

    DocSection {
        title: "Color scheme management";
        description-md: @markdown(
			"As mentioned previously, sleek-ui uses the [Palette.color-scheme](https://docs.slint.dev/latest/docs/slint/reference/std-widgets/globals/palette/) property to determine which theme to use.\n"
			"You can programmatically switch the color scheme by changing the value of the `Palette.color-scheme` property.\n"
			"Or you can set one of the light and dark themes as the value of the `UAppTheme.theme` property which then defines the values of all the design tokens. Doing so will result in no automatic color scheme switch."
		);
        link-clicked(url) => {
            Platform.open-url(url);
        }
    }

    DocSection {
        title: "Default colors and ant design editor";
        description-md: @markdown(
			"As sleek-ui is based on [Ant Design](https://ant.design/), you have a set of pre-declared colors available [here](default-colors).\n"
			"You can also use the official [Ant Design theme editor](https://ant.design/theme-editor) to easily generate colors for your application."
		);
        link-clicked(url) => {
            if url == "default-colors" {
                UMenuLogic.current-link = url;
            } else {
                Platform.open-url(url);
            }
        }
    }

    config-struct := DocSection {
        title: "UAppThemeConfig struct";
    }

    DocCode {
        code: "struct UAppThemeConfig {\n    // Animation duration\n    animation-duration: duration,\n\n    // Primary colors\n    primary: UPrimaryColor,\n    success: UPrimaryColor,\n    warning: UPrimaryColor,\n    danger: UPrimaryColor,\n\n    // Background colors\n    bg-layout: brush,\n    bg-container: brush,\n    bg-elevated: brush,\n    bg-spotlight: brush,\n\n    // Fill colors\n    color-fill-plus: brush,\n    color-fill: brush,\n    color-fill-secondary: brush,\n    color-fill-tertiary: brush,\n    color-fill-quaternary: brush,\n\n    // Borders\n    border-width-base: length,\n    border: brush,\n    border-secondary: brush,\n    separator: brush,\n\n    // Shadow\n    shadow-color: brush,\n    shadow-blur: length,\n    shadow-x-offset: length,\n    shadow-y-offset: length,\n\n    // Focus display\n    focus-color: brush,\n    focus-border-width: length,\n\n    // Text colors\n    // Color used for the text in widgets with a primary color as a background.\n    primary-text: brush,\n    inverse-text: brush,\n    text: brush,\n    text-secondary: brush,\n    text-tertiary: brush,\n    text-quaternary: brush,\n    text-disabled: brush,\n\n    // Font sizes\n    font-size-smaller: length,\n    font-size-small: length,\n    font-size-base: length,\n    font-size-medium: length,\n    font-size-big: length,\n    font-size-bigger: length,\n    \n    // Icons\n    icon-size-base: length,\n\n    // Padding\n    padding-vertical: length,\n    padding-horizontal: length,\n    padding-small: length,\n    padding-base: length,\n    padding-medium: length,\n    padding-big: length,\n    padding-bigger: length,\n\n    // Spacing\n    spacing-small: length,\n    spacing-base: length,\n    spacing-medium: length,\n    spacing-big: length,\n    spacing-bigger: length,\n\n    // Radius\n    radius-small: length,\n    radius-base: length,\n    radius-medium: length,\n    radius-large: length,\n    radius-round: length,\n    radius-circle: length,}";
    }
}
