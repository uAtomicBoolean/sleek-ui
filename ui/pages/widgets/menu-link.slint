import { UAppTheme } from "../../sleek-ui/app-theme.slint";
import { UTitle } from "../../sleek-ui/widgets.slint";

import {
    DocTitle,
    DocDescription,
    WidgetPresentation,
    DocSection,
    DocCode,
} from "../../components/doc-widgets.slint";
import { PageBase } from "../../components/page-base.slint";
import { AppLogic } from "../../app-logic.slint";


export component MenuPageLink inherits PageBase {
    UTitle {
        level: 3;
        text: "Menu link";
    }

    DocDescription {
        text: "A link to use in the menu or submenu widget.";
    }

    DocSection {
        title: "Basic usage";
        description-md: @markdown(
			"Add a link to a menu by setting the `id` and `name`."
		);
    }

    DocCode {
        code: "UMenuLink {\n    id: \"first-page\";\n    name: \"First page\";\n}";
    }

    DocSection {
        title: "Disabled link";
        description-md: @markdown(
			"You can disable a link by setting the `enabled` property to false."
		);
    }

    DocCode {
        code: "UMenuLink {\n    enabled: false;\n}";
    }

    DocSection {
        title: "Selected link";
        description-md: @markdown(
			"You can check if a link is selected by checking the `is-selected` property or "
			"the `UMenuLogic.current-link` global property."
		);
    }

    DocCode {
        code: "UMenuLink {\n    activated => {\n        debug(self.is-selected);\n    }\n}";
    }

    DocSection {
        title: "Activated callback";
        description-md: @markdown(
			"Clicking on the link will fire the `activated` callback (only if the link is not the current link)."
		);
    }

    DocCode {
        code: "UMenuLink {\n    activated => {\n        debug(\"Link \\{self.id} has been clicked.\");\n    }\n}";
    }
}
