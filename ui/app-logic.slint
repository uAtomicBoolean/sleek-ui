import { SlintDocPage } from "structs/doc-content.slint";


export global AppLogic {
    in-out property <float> scale-factor: 100;
    pure callback get-version-number() -> string;
    pure callback is-wasm() -> bool;
    pure callback open-url(url: string);
    pure callback update-scale-factor(scale-factor: float);
    pure callback get-page-content(page-id: string) -> SlintDocPage;
}
